{
  "name": "amrita",
  "version": "0.0.0",
  "private": true,
  "description": "Amrita — a chat-first, project-aware, multi-channel agent OS (v2, monorepo)",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "amritad": "node packages/daemon/src/bin/amritad.ts",
    "amrita": "node packages/cli/src/bin/amrita.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
